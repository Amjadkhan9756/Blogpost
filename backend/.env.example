# Copy this file to .env and fill in your values. Do NOT commit .env.

# MongoDB Atlas connection string (create a free cluster at https://cloud.mongodb.com)
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority

# Optional: secret for admin wipe endpoint
ADMIN_WIPE_SECRET=your-secret-here

# Optional: port (default 8080)
# PORT=8080
